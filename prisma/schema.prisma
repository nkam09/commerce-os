// Commerce OS — Prisma Schema
// Run: npx prisma migrate dev --name init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── AUTH ─────────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  marketplaces    Marketplace[]
  products        Product[]
  purchaseOrders  PurchaseOrder[]
  shipments       Shipment[]
  reimbursements  Reimbursement[]
  expenses        Expense[]
  projects        Project[]
  tasks           Task[]
  cashEvents      CashEvent[]
  aiInsights      AiInsight[]
  syncConnections SyncConnection[]
  settings        UserSettings?

  @@map("users")
}

model UserSettings {
  id            String  @id @default(cuid())
  userId        String  @unique
  cashFloor     Float   @default(20000)
  defaultVelocityWindow Int @default(30) // days
  timezone      String  @default("America/New_York")
  currency      String  @default("USD")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}

// ─── MARKETPLACE ──────────────────────────────────────────────────────────────

model Marketplace {
  id              String @id @default(cuid())
  userId          String
  marketplaceCode String // US, UK, DE, etc.
  region          String // NA, EU, FE
  currency        String @default("USD")
  timezone        String @default("America/New_York")

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  dailySales      DailySales[]
  dailyAds        DailyAds[]
  dailyFees       DailyFees[]
  inventorySnaps  InventorySnapshot[]

  @@unique([userId, marketplaceCode])
  @@map("marketplaces")
}

// ─── PRODUCTS ─────────────────────────────────────────────────────────────────

model Product {
  id        String        @id @default(cuid())
  userId    String
  asin      String
  sku       String
  fnsku     String?
  title     String?
  brand     String?
  imageUrl  String?
  status    ProductStatus @default(ACTIVE)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  user              User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  settings          ProductSettings?
  dailySales        DailySales[]
  dailyAds          DailyAds[]
  dailyFees         DailyFees[]
  inventorySnaps    InventorySnapshot[]
  purchaseOrderItems PurchaseOrderItem[]
  shipmentItems     ShipmentItem[]
  reimbursements    Reimbursement[]
  tasks             Task[]
  aiInsights        AiInsight[]

  @@unique([userId, asin])
  @@map("products")
}

enum ProductStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

model ProductSettings {
  id                  String   @id @default(cuid())
  productId           String   @unique
  landedCogsPerUnit   Float    @default(0)
  freightPerUnit      Float    @default(0)
  prepPerUnit         Float    @default(0)
  overheadPerUnit     Float    @default(0)
  safetyStockDays     Int      @default(14)
  productionLeadDays  Int      @default(30)
  shippingLeadDays    Int      @default(30)
  receivingBufferDays Int      @default(7)
  reorderCoverageDays Int      @default(90)
  reorderMinQty       Int?
  reorderCasePack     Int?
  targetMargin        Float?
  targetAcos          Float?
  targetTacos         Float?
  updatedAt           DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_settings")
}

// ─── DAILY FACTS ──────────────────────────────────────────────────────────────

model DailySales {
  id             String   @id @default(cuid())
  productId      String
  marketplaceId  String
  date           DateTime @db.Date
  unitsSold      Int      @default(0)
  orderCount     Int      @default(0)
  grossSales     Float    @default(0)
  averageSellPrice Float?
  refundCount    Int      @default(0)
  refundAmount   Float    @default(0)
  adSales        Float?   // convenience copy from ads
  sessions       Int?
  conversionRate Float?

  product     Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  marketplace Marketplace @relation(fields: [marketplaceId], references: [id], onDelete: Cascade)

  @@unique([productId, marketplaceId, date])
  @@map("daily_sales")
}

model DailyAds {
  id             String   @id @default(cuid())
  productId      String?
  marketplaceId  String
  campaignId     String?
  campaignName   String?
  date           DateTime @db.Date
  spend          Float    @default(0)
  attributedSales Float   @default(0)
  clicks         Int      @default(0)
  impressions    Int      @default(0)
  orders         Int      @default(0)
  acos           Float?
  roas           Float?
  cpc            Float?

  product     Product?    @relation(fields: [productId], references: [id], onDelete: SetNull)
  marketplace Marketplace @relation(fields: [marketplaceId], references: [id], onDelete: Cascade)

  @@unique([campaignId, marketplaceId, date])
  @@map("daily_ads")
}

model DailyFees {
  id                    String   @id @default(cuid())
  productId             String
  marketplaceId         String
  date                  DateTime @db.Date
  referralFees          Float    @default(0)
  fbaFees               Float    @default(0)
  storageFees           Float    @default(0)
  returnProcessingFees  Float    @default(0)
  otherFees             Float    @default(0)

  product     Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  marketplace Marketplace @relation(fields: [marketplaceId], references: [id], onDelete: Cascade)

  @@unique([productId, marketplaceId, date])
  @@map("daily_fees")
}

// ─── INVENTORY ────────────────────────────────────────────────────────────────

model InventorySnapshot {
  id            String   @id @default(cuid())
  productId     String
  marketplaceId String
  snapshotAt    DateTime @default(now())
  available     Int      @default(0)
  reserved      Int      @default(0)
  inbound       Int      @default(0)
  awd           Int      @default(0)
  warehouse     String?

  product     Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  marketplace Marketplace @relation(fields: [marketplaceId], references: [id], onDelete: Cascade)

  @@map("inventory_snapshots")
}

// ─── PURCHASE ORDERS ──────────────────────────────────────────────────────────

model PurchaseOrder {
  id               String          @id @default(cuid())
  userId           String
  supplierName     String
  poNumber         String?
  status           PoStatus        @default(DRAFT)
  orderDate        DateTime        @db.Date
  depositDueDate   DateTime?       @db.Date
  balanceDueDate   DateTime?       @db.Date
  etaDate          DateTime?       @db.Date
  depositAmount    Float           @default(0)
  balanceAmount    Float           @default(0)
  freightEstimate  Float           @default(0)
  notes            String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     PurchaseOrderItem[]
  shipments Shipment[]

  @@map("purchase_orders")
}

enum PoStatus {
  DRAFT
  APPROVED
  IN_PRODUCTION
  SHIPPED
  RECEIVED
  CLOSED
}

model PurchaseOrderItem {
  id              String @id @default(cuid())
  purchaseOrderId String
  productId       String
  qtyUnits        Int
  unitCost        Float
  totalCost       Float  // computed: qty * unitCost

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  product       Product       @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([purchaseOrderId, productId])
  @@map("purchase_order_items")
}

// ─── SHIPMENTS ────────────────────────────────────────────────────────────────

model Shipment {
  id                  String        @id @default(cuid())
  userId              String
  linkedPoId          String?
  shipmentName        String
  origin              String?
  destination         String?
  mode                ShipmentMode  @default(SEA)
  stage               ShipmentStage @default(BOOKED)
  etaDate             DateTime?     @db.Date
  actualArrivalDate   DateTime?     @db.Date
  freightCostEstimate Float         @default(0)
  notes               String?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  purchaseOrder PurchaseOrder? @relation(fields: [linkedPoId], references: [id], onDelete: SetNull)
  items         ShipmentItem[]

  @@map("shipments")
}

enum ShipmentMode {
  SEA
  AIR
  PARCEL
  TRUCK
  RAIL
}

enum ShipmentStage {
  BOOKED
  IN_PRODUCTION
  ON_WATER
  CUSTOMS
  DELIVERED
  CHECKED_IN
}

model ShipmentItem {
  id         String @id @default(cuid())
  shipmentId String
  productId  String
  qtyUnits   Int

  shipment Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([shipmentId, productId])
  @@map("shipment_items")
}

// ─── REIMBURSEMENTS ───────────────────────────────────────────────────────────

model Reimbursement {
  id               String              @id @default(cuid())
  userId           String
  productId        String?
  issueType        String
  amountEstimated  Float               @default(0)
  amountRecovered  Float               @default(0)
  status           ReimbursementStatus @default(OPEN)
  openedAt         DateTime            @default(now())
  closedAt         DateTime?
  notes            String?

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@map("reimbursements")
}

enum ReimbursementStatus {
  OPEN
  SUBMITTED
  FOLLOW_UP
  CLOSED
}

// ─── EXPENSES ─────────────────────────────────────────────────────────────────

model Expense {
  id        String           @id @default(cuid())
  userId    String
  category  String
  vendor    String?
  amount    Float
  frequency ExpenseFrequency @default(MONTHLY)
  startDate DateTime         @db.Date
  endDate   DateTime?        @db.Date
  notes     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("expenses")
}

enum ExpenseFrequency {
  ONE_TIME
  WEEKLY
  MONTHLY
  YEARLY
}

// ─── PROJECTS & TASKS ─────────────────────────────────────────────────────────

model Project {
  id              String        @id @default(cuid())
  userId          String
  name            String
  status          ProjectStatus @default(QUEUED)
  owner           String?
  dueDate         DateTime?     @db.Date
  progressPercent Int           @default(0)
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks Task[]

  @@map("projects")
}

enum ProjectStatus {
  QUEUED
  IN_PROGRESS
  REVIEW
  BLOCKED
  COMPLETE
}

model Task {
  id        String     @id @default(cuid())
  userId    String
  projectId String?
  productId String?
  title     String
  status    TaskStatus @default(TODO)
  priority  Priority   @default(MEDIUM)
  owner     String?
  dueDate   DateTime?  @db.Date
  notes     String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@map("tasks")
}

enum TaskStatus {
  TODO
  DOING
  BLOCKED
  DONE
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

// ─── CASH EVENTS ──────────────────────────────────────────────────────────────

model CashEvent {
  id               String          @id @default(cuid())
  userId           String
  eventDate        DateTime        @db.Date
  type             CashEventType
  direction        CashDirection
  amount           Float
  linkedObjectType String?         // "purchase_order" | "shipment" | "expense"
  linkedObjectId   String?
  notes            String?
  createdAt        DateTime        @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("cash_events")
}

enum CashEventType {
  AMAZON_PAYOUT
  AD_SPEND
  PO_DEPOSIT
  PO_BALANCE
  FREIGHT
  LOAN
  PAYROLL
  SOFTWARE
  REIMBURSEMENT
  TAX
  OTHER
}

enum CashDirection {
  INFLOW
  OUTFLOW
}

// ─── AI INSIGHTS ──────────────────────────────────────────────────────────────

model AiInsight {
  id          String        @id @default(cuid())
  userId      String
  productId   String?
  scope       InsightScope
  insightType InsightType
  severity    Severity
  title       String
  body        String        @db.Text
  actionText  String?
  status      InsightStatus @default(OPEN)
  createdAt   DateTime      @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@map("ai_insights")
}

enum InsightScope {
  COMPANY
  PRODUCT
  CASH
  INVENTORY
  ADS
}

enum InsightType {
  SUMMARY
  ALERT
  SUGGESTION
  ANOMALY
}

enum Severity {
  LOW
  MEDIUM
  HIGH
}

enum InsightStatus {
  OPEN
  DISMISSED
  ACTED_ON
}

// ─── SYNC CONNECTIONS ─────────────────────────────────────────────────────────

model SyncConnection {
  id                String           @id @default(cuid())
  userId            String
  provider          String           // "amazon_sp_api" | "amazon_ads"
  externalAccountId String?
  status            ConnectionStatus @default(ACTIVE)
  lastSyncAt        DateTime?
  metadataJson      String?          @db.Text // encrypted connection metadata
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@map("sync_connections")
}

enum ConnectionStatus {
  ACTIVE
  INACTIVE
  ERROR
  REVOKED
}
